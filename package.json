{
  "name": "wayfarer",
  "version": "1.0.0",
  "description": "The API client that can't rug-pull you — a local-first, no-account API testing client with collections, environments, an encrypted secrets vault, pre/post-request scripts, and a Postman-grade response viewer, entirely in the browser.",
  "license": "MIT",
  "private": true,
  "author": "Ashwin Sathian",
  "homepage": "https://api-sandbox.ashwinsathian.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AshwinSathian/wayfarer.git"
  },
  "bugs": {
    "url": "https://github.com/AshwinSathian/wayfarer/issues"
  },
  "keywords": [
    "angular",
    "typescript",
    "api-client",
    "api-testing",
    "rest-client",
    "indexeddb",
    "primeng",
    "local-first",
    "developer-tools",
    "http-client"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless",
    "lint": "ng lint",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "bridge": "node local-bridge/bin/cli.js",
    "bridge:test": "node --test local-bridge/test/"
  },
  "dependencies": {
    "@angular/animations": "^20.3.4",
    "@angular/cdk": "^20.0.3",
    "@angular/common": "^20.3.4",
    "@angular/compiler": "^20.3.4",
    "@angular/core": "^20.3.4",
    "@angular/forms": "^20.3.4",
    "@angular/platform-browser": "^20.3.4",
    "@angular/platform-browser-dynamic": "^20.3.4",
    "@angular/router": "^20.3.4",
    "@angular/service-worker": "^20.3.4",
    "@primeng/themes": "^20.2.0",
    "idb": "^8.0.3",
    "monaco-editor": "^0.54.0",
    "primeicons": "^7.0.0",
    "primeng": "^20.0.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.5",
    "@angular/cli": "^20.3.5",
    "@angular/compiler-cli": "^20.3.4",
    "@angular/language-service": "^20.3.4",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/jasmine": "3.10.3",
    "@types/node": "^20.12.7",
    "angular-eslint": "21.0.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.1",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "jasmine-core": "3.10.1",
    "karma": "6.4.2",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.0",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "1.7.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "tslib": "^2.8.1",
    "typescript": "~5.9",
    "typescript-eslint": "8.46.4",
    "wrangler": "^4.112.0",
    "zone.js": "^0.15.1"
  }
}
